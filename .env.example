# Example environment for local development, production deploys, and repo scripts.
# Copy the variables you need into .env.local or your deployment system.
# Deprecated and ignored: HUB_DEV_AUTH and VITE_HUB_DEV_AUTH.

# App HTTP port for the hub API service.
PORT=3001
# Node environment for the server runtime.
NODE_ENV=production
# Bind address for the collab server.
HOST=0.0.0.0
# SQLite database path used by the hub API and collab services.
HUB_DB_PATH=/absolute/path/to/hub.sqlite
# Internal base URL the collab service uses to call the hub API.
HUB_API_URL=http://127.0.0.1:3001
# External hub API base URL for smoke tests and live checks.
HUB_API_BASE_URL=http://127.0.0.1:3001
# Public hub base URL used by live checks and scripts.
HUB_BASE_URL=https://hub.example.com
# Browser dev proxy target used by Vite in local development.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:3001

# Allowed browser origin for POSTMARK-backed routes.
POSTMARK_ALLOWED_ORIGIN=https://hub.example.com
# Postmark server token used by hub-api to send invite emails.
POSTMARK_SERVER_TOKEN=replace-me
# Sender email used by hub-api invite emails.
POSTMARK_FROM_EMAIL=no-reply@example.com
# Optional Postmark message stream used for invite emails.
POSTMARK_MESSAGE_STREAM=outbound
# Optional timeout for Postmark API requests in milliseconds.
POSTMARK_REQUEST_TIMEOUT_MS=15000
# Keycloak issuer URL used to verify bearer tokens.
KEYCLOAK_ISSUER=https://auth.example.com/realms/example-realm
# Expected Keycloak audiences for JWT verification.
KEYCLOAK_AUDIENCE=account,example-hub
# JWKS cache duration in milliseconds.
KEYCLOAK_JWKS_CACHE_MAX_AGE_MS=600000
# Public Keycloak URL used by the browser app and admin scripts.
KEYCLOAK_URL=https://auth.example.com
# Keycloak realm used by the browser app and admin scripts.
KEYCLOAK_REALM=example-realm
# Keycloak client id used by the browser app and token minting scripts.
KEYCLOAK_CLIENT_ID=example-hub
# Redirect URI used by token minting helpers.
KEYCLOAK_REDIRECT_URI=https://hub.example.com/
# Canonical owner email used by hub policy authorization.
HUB_OWNER_EMAIL=owner@example.com
# Keycloak admin username used by provisioning and cleanup scripts.
KEYCLOAK_ADMIN_USERNAME=admin
# Keycloak admin password used by provisioning and cleanup scripts.
KEYCLOAK_ADMIN_PASSWORD=replace-me
# Optional lifetime in seconds for Keycloak invite onboarding links.
KEYCLOAK_INVITE_ACTION_LIFESPAN_SECONDS=604800

# Reset schema automatically when explicitly allowed.
HUB_API_ALLOW_SCHEMA_RESET=false
# Nextcloud base URL used by server integrations and UI links.
NEXTCLOUD_BASE_URL=https://cloud.example.com
# Nextcloud username used by the hub API server.
NEXTCLOUD_USER=nextcloud-user
# Nextcloud app password used by the hub API server.
NEXTCLOUD_APP_PASSWORD=replace-me
# Default timeout for hub API fetches from the collab sidecar.
HUB_API_FETCH_TIMEOUT_MS=8000
# TTL for collab websocket authorization tickets in milliseconds.
HUB_COLLAB_TICKET_TTL_MS=120000
# Shared Matrix registration secret used by the hub-to-Tuwunel bridge.
TUWUNEL_REGISTRATION_SHARED_SECRET=replace-with-long-random-string
# Internal Tuwunel base URL used by hub-api for Matrix provisioning.
TUWUNEL_INTERNAL_URL=http://tuwunel:6167
# Encryption key used by hub-api to store Matrix account passwords at rest.
MATRIX_ACCOUNT_ENCRYPTION_KEY=replace-with-long-random-string
# Allowed origins for collab websocket upgrades.
HUB_COLLAB_ALLOWED_ORIGINS=https://hub.example.com
# Require Origin headers on collab websocket upgrades.
HUB_COLLAB_REQUIRE_ORIGIN=false
# Maximum simultaneous collab websocket connections.
HUB_COLLAB_MAX_CONNECTIONS=250
# Maximum simultaneously loaded collab documents.
HUB_COLLAB_MAX_DOCUMENTS=500
# Debounce window before collab snapshots are saved.
HUB_COLLAB_SAVE_DEBOUNCE_MS=750

# Keycloak URL exposed to the browser app.
VITE_KEYCLOAK_URL=https://auth.example.com
# Keycloak realm exposed to the browser app.
VITE_KEYCLOAK_REALM=example-realm
# Keycloak client id exposed to the browser app.
VITE_KEYCLOAK_CLIENT_ID=example-hub
# Collab websocket URL exposed to the browser app.
VITE_HUB_COLLAB_WS_URL=wss://collab.example.com
# Hub live websocket URL exposed to the browser app.
VITE_HUB_LIVE_WS_URL=wss://api.example.com/api/hub/live
# Enable browser mock data instead of real services.
VITE_USE_MOCKS=false
# Wake webhook used by the client-side n8n trigger.
VITE_N8N_WAKE_WEBHOOK_URL=https://n8n.example.com/webhook/wake
# Sleep webhook used by the client-side n8n trigger.
VITE_N8N_SLEEP_WEBHOOK_URL=https://n8n.example.com/webhook/sleep
# Default sender email exposed to client integrations.
VITE_POSTMARK_FROM_EMAIL=no-reply@example.com
# ntfy topic URL used by the browser app.
VITE_NTFY_TOPIC_URL=https://ntfy.example.com/topic
# Browser builds must not carry GitHub, OpenProject, Nextcloud, or Postmark credentials.
# Route those integrations through hub-api or the future desktop bridge instead.

# Base URL used by Playwright and workflow e2e helpers.
BASE_URL=http://127.0.0.1:5173
# Default project id used by workflow helpers.
PROJECT_ID=backend-pilot
# Default pane id used by workflow helpers.
PANE_ID=pane-id
# Private pane id used by workflow helpers.
PRIVATE_PANE_ID=private-pane-id
# Primary test account email for e2e helpers.
TEST_EMAIL_A=user-a@example.com
# Primary test account password for e2e helpers.
TEST_PASSWORD_A=replace-me
# Secondary test account email for e2e helpers.
TEST_EMAIL_B=user-b@example.com
# Secondary test account password for e2e helpers.
TEST_PASSWORD_B=replace-me
# Workflow calendar mode for workflow e2e helpers.
WORKFLOW_CALENDAR_MODE=project
# Toggle workflow module coverage in workflow e2e helpers.
WORKFLOW_MODULES=true
# Toggle invite coverage in workflow e2e helpers.
WORKFLOW_INVITES=false

# Generic member access token used by live checks.
HUB_ACCESS_TOKEN=replace-me
# Owner access token used by live checks.
HUB_OWNER_ACCESS_TOKEN=replace-me
# Collaborator access token used by live checks.
HUB_COLLAB_ACCESS_TOKEN=replace-me
# Non-member access token used by live checks.
HUB_NON_MEMBER_ACCESS_TOKEN=replace-me
# Non-invited access token used by Keycloak gate checks.
HUB_NON_INVITED_ACCESS_TOKEN=replace-me
# Expected owner email used by policy checks.
HUB_OWNER_EMAIL_EXPECTED=owner@example.com
# Require edge-gate behavior in hub policy checks.
HUB_EXPECT_EDGE_GATE=false
# Shared timeout for live check scripts in milliseconds.
HUB_REQUEST_TIMEOUT_MS=15000
# Fail authz runtime checks when a scenario must be skipped.
HUB_AUTHZ_FAIL_ON_SKIPPED=false
# Default project id for live checks.
HUB_PROJECT_ID=backend-pilot
# Secondary project id for authz runtime checks.
HUB_OTHER_PROJECT_ID=other-project-id
# Project name used by fixture scripts.
HUB_PROJECT_NAME=Backend Pilot
# Include collab smoke coverage during core-gate checks.
HUB_INCLUDE_COLLAB_SMOKE=false
# Collab websocket URL used by live checks.
HUB_COLLAB_WS_URL=wss://collab.example.com
# Expected collab websocket URL used by preflight checks.
HUB_COLLAB_WS_URL_EXPECTED=wss://collab.example.com
# Explicit collab readiness endpoint used by preflight checks.
HUB_COLLAB_READY_URL=https://api.example.com/api/hub/health
# Sidecar secret used by collab preflight checks.
HUB_COLLAB_TOKEN_SECRET_SIDECAR=replace-with-long-random-string
# Socket secret used by collab preflight checks.
HUB_COLLAB_TOKEN_SECRET_SOCKET=replace-with-long-random-string
# Token for the author of the seeded collab note.
HUB_COLLAB_NOTE_AUTHOR_TOKEN=replace-me
# Explicitly expired collab token used by websocket checks.
HUB_COLLAB_EXPIRED_TOKEN=expired-token
# Seeded collab note id used by websocket checks.
HUB_COLLAB_NOTE_ID=note-id
# Project id used by collab websocket live checks.
HUB_COLLAB_PROJECT_ID=backend-pilot
# Timeout for collab websocket live checks in milliseconds.
HUB_COLLAB_TIMEOUT_MS=15000
# Project id used by Nextcloud live checks.
HUB_NEXTCLOUD_PROJECT_ID=project-id
# Remove Nextcloud test artifacts after live checks.
HUB_NEXTCLOUD_CLEANUP=0
# Project id used by OpenProject live checks.
HUB_OPENPROJECT_PROJECT_ID=project-id
# Remove OpenProject test artifacts after live checks.
HUB_OPENPROJECT_CLEANUP=0

# Reset smoke-user passwords during provisioning.
HUB_SMOKE_RESET_PASSWORDS=false
# Output file for minted smoke tokens.
HUB_SMOKE_TOKENS_FILE=.env.contract-smoke.tokens.local
# Username for smoke test user A.
HUB_SMOKE_USER_A_USERNAME=hub-smoke-a
# Password for smoke test user A.
HUB_SMOKE_USER_A_PASSWORD=replace-me
# Email for smoke test user A.
HUB_SMOKE_USER_A_EMAIL=hub-smoke-a@example.com
# First name for smoke test user A.
HUB_SMOKE_USER_A_FIRST_NAME=Hub
# Last name for smoke test user A.
HUB_SMOKE_USER_A_LAST_NAME=SmokeA
# Username for smoke test user B.
HUB_SMOKE_USER_B_USERNAME=hub-smoke-b
# Password for smoke test user B.
HUB_SMOKE_USER_B_PASSWORD=replace-me
# Email for smoke test user B.
HUB_SMOKE_USER_B_EMAIL=hub-smoke-b@example.com
# First name for smoke test user B.
HUB_SMOKE_USER_B_FIRST_NAME=Hub
# Last name for smoke test user B.
HUB_SMOKE_USER_B_LAST_NAME=SmokeB

# Corpus file list for calendar NLP regression tests.
CALENDAR_NLP_CORPUS_PATHS=scripts/calendar-nlp/corpus.json
# Maximum failing corpus cases before the NLP test aborts.
CALENDAR_NLP_MAX_FAILURES=20
# Confidence tolerance used by calendar NLP regression tests.
CALENDAR_NLP_CONFIDENCE_TOLERANCE=0.2

# Token A used by the contract smoke test.
TOKEN_A=replace-me
# Token B used by the contract smoke test.
TOKEN_B=replace-me
