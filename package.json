{
  "name": "hub-os",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b tsconfig.app.json && vite build",
    "preview": "vite preview",
    "typecheck": "tsc -p tsconfig.app.json --noEmit",
    "test:e2e": "bash scripts/run-playwright-regression.sh",
    "test:e2e:workflow": "bash scripts/run-playwright-workflow.sh",
    "test:nlp": "node --experimental-strip-types --test scripts/calendar-nlp/corpus.test.mjs scripts/calendar-nlp/weekday-semantics.test.mjs scripts/calendar-nlp/enhancements.test.mjs",
    "test:hub-provenance": "node --experimental-strip-types --test scripts/hub-provenance-regression.test.mjs",
    "parse-cli": "node --experimental-strip-types scripts/calendar-nlp/parse-cli.mjs",
    "lint": "eslint .",
    "check:a11y": "node scripts/check-a11y.mjs",
    "check:tokens": "node scripts/check-token-compliance.mjs",
    "check:no-inline-styles": "node scripts/check-no-inline-styles.mjs",
    "check:css-drift": "node scripts/check-css-drift.mjs",
    "check:layout-primitives": "node scripts/check-layout-primitives.mjs",
    "check:headings": "node scripts/check-headings.mjs",
    "validate": "npm run typecheck && npm run lint && npm run check:authz && npm run build",
    "check:authz": "node scripts/check-authz.mjs",
    "check:authz-runtime": "node scripts/check-authz-runtime.mjs",
    "check:hub-core-gate": "node scripts/check-hub-core-gate.mjs",
    "check:hub-sqlite-lock": "node scripts/check-hub-sqlite-lock.mjs",
    "check:hub-core-gate:live": "bash scripts/check-hub-live.sh",
    "check:hub-live": "bash scripts/check-hub-live.sh",
    "check:hub-policy-live": "node scripts/check-hub-policy-live.mjs",
    "check:openproject-live": "node scripts/check-openproject-live.mjs",
    "check:nextcloud-live": "node scripts/check-nextcloud-live.mjs",
    "fixture:hub-project": "node scripts/ensure-hub-project-fixture.mjs",
    "cleanup:nextcloud-tests": "node scripts/cleanup-nextcloud-test-files.mjs",
    "cleanup:openproject-tests": "node scripts/cleanup-openproject-test-work-packages.mjs",
    "keycloak:close-club": "node scripts/keycloak-close-club.mjs",
    "keycloak:verify-closed": "node scripts/keycloak-verify-closed.mjs",
    "clean": "node scripts/clean.mjs",
    "smoke:ensure-users": "node scripts/ensure-contract-smoke-users.mjs",
    "smoke:mint-tokens": "node scripts/mint-contract-smoke-tokens.mjs",
    "deploy:root": "bash scripts/deploy-root.sh",
    "deploy:hub-api": "bash scripts/deploy-hub-api.sh",
    "deploy:postmark": "npm run deploy:hub-api",
    "deploy:collab": "bash scripts/deploy-collab.sh",
    "deploy:tuwunel": "bash scripts/deploy-tuwunel.sh",
    "check:collab-preflight": "node scripts/check-collab-preflight.mjs",
    "check:collab-live": "node scripts/check-collab-ws-live.mjs",
    "check:cleanup-live": "node scripts/cleanup-live-test-entities.mjs",
    "deploy": "npm run deploy:root && npm run deploy:hub-api && npm run deploy:collab && npm run deploy:tuwunel"
  },
  "engines": {
    "node": ">=22.13.0"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@hocuspocus/provider": "^3.4.4",
    "@lexical/code": "^0.40.0",
    "@lexical/link": "^0.40.0",
    "@lexical/list": "^0.40.0",
    "@lexical/markdown": "^0.40.0",
    "@lexical/react": "^0.40.0",
    "@lexical/rich-text": "^0.40.0",
    "@lexical/yjs": "^0.40.0",
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.19",
    "chrono-node": "^2.9.0",
    "cmdk": "^1.1.1",
    "keycloak-js": "^26.2.3",
    "lexical": "^0.40.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.0",
    "sonner": "^2.0.7",
    "ws": "^8.18.3",
    "y-indexeddb": "^9.0.12",
    "y-websocket": "^3.0.0",
    "yjs": "^13.6.29"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.3",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.2.0",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^9.39.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.0",
    "tailwindcss": "^4.2.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1"
  }
}
